PORT=8081
HOST=0.0.0.0
NODE_ENV=development

POSTGRES_DB=bambu_connector
POSTGRES_USER=connector
POSTGRES_PASSWORD=connector
POSTGRES_PORT=5434
DATABASE_URL=postgresql://connector:connector@connector-db:5432/bambu_connector

# Production: use https://. Local/testing may use http:// (e.g. http://printing-web:3000).
PRINTING_WEB_BASE_URL=http://printing-web:3000
SERVICE_AUTH_SHARED_SECRET=change-me
ADMIN_AUTH_SECRET=change-me-at-least-16-chars
# Optional: if set, /metrics requires Authorization: Bearer <METRICS_AUTH_SECRET>
# METRICS_AUTH_SECRET=

BAMBU_PRINTERS_JSON=[]

YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
